# apps/admin environment variables (NAMES ONLY — never commit real values).
# Copy to apps/admin/.env.local and fill in. .env.local is git-ignored.

# Supabase (same project shared with the storefront)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — privileged server actions. NEVER expose / prefix with NEXT_PUBLIC.
SUPABASE_SERVICE_ROLE_KEY=

# App identity / links
NEXT_PUBLIC_APP_URL=          # this admin app's own public URL
NEXT_PUBLIC_APP_NAME=
NEXT_PUBLIC_CURRENCY=

# WhatsApp Cloud API (receipt PDF send) — server-only
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
