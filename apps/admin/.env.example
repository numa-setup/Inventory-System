# apps/admin environment variables (NAMES ONLY — never commit real values).
# Copy to apps/admin/.env.local and fill in. .env.local is git-ignored.
# For the Railway deploy, set these in the service's Variables — see ../../DEPLOYMENT.md.

# Supabase (same project shared with the storefront)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — privileged server actions + auth admin. NEVER expose / prefix with NEXT_PUBLIC.
SUPABASE_SERVICE_ROLE_KEY=

# App identity / links
NEXT_PUBLIC_APP_URL=          # this admin app's own public URL (used in the password-reset link)
NEXT_PUBLIC_APP_NAME=        # optional
NEXT_PUBLIC_CURRENCY=        # optional

# --- Admin authentication (Part 2) ---
# Signs the OTP-verified session cookie (middleware 2nd factor). Use a long random
# string, e.g. `openssl rand -hex 32`. REQUIRED for the admin to be reachable.
ADMIN_OTP_SECRET=
# Resend — sends the login OTP + password-reset emails (server-only)
RESEND_API_KEY=
AUTH_EMAIL_FROM=             # verified sender, e.g. "Hamza Store <noreply@yourdomain.com>"

# Used ONLY by `node scripts/create-admin.mjs` to create/update the initial admin.
# Set, run the script once, then you may clear them. Never commit real values.
ADMIN_EMAIL=
ADMIN_PASSWORD=
