# apps/storefront environment variables (NAMES ONLY — never commit real values).
# Copy to apps/storefront/.env.local and fill in. .env.local is git-ignored.

# Supabase (same project shared with the admin app)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — storefront reads/writes via service-role server actions.
# NEVER expose / prefix with NEXT_PUBLIC.
SUPABASE_SERVICE_ROLE_KEY=

# App identity / links
NEXT_PUBLIC_APP_URL=          # this storefront's own public URL (used in payment return URLs)
NEXT_PUBLIC_APP_NAME=
NEXT_PUBLIC_CURRENCY=
NEXT_PUBLIC_ADMIN_URL=        # the admin app URL (storefront "Staff login" link target)

# Reservation-expiry cron route guard — server-only
CRON_SECRET=

# Order notifications — server-only
RESEND_API_KEY=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
