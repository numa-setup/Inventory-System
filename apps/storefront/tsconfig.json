{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"],
      "@hamza/shared": ["../../packages/shared/src/index.ts"],
      "@hamza/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts",
    "../../packages/shared/src/**/*.ts",
    "../../packages/shared/src/**/*.tsx"
  ],
  "exclude": ["node_modules", "../../packages/shared/src/**/*.test.ts"]
}
