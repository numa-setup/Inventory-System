{
  "name": "hamza-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Hamza General Store monorepo — apps/admin (inventory + POS), apps/storefront (customer e-commerce), packages/shared. One Supabase database shared by both apps.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "dev:admin": "npm run dev -w @hamza/admin",
    "dev:storefront": "npm run dev -w @hamza/storefront",
    "db:migrate": "node scripts/migrate.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "pg": "^8.21.0",
    "typescript": "^5.7.2"
  }
}
